  "acceptance_criteria": [
    "KeychainHelper is a struct (not class)",
    "read(key:) returns nil when no item exists for the given key",
    "write(key:value:) upserts: adds on first write, updates on subsequent writes for the same key",
    "kSecClassGenericPassword is used for both operations",
    "No throwing or crashing on expected Keychain errors (duplicate item, not found)"
